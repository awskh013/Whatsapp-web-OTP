# ── Server ─────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — no need to add it manually
PORT=3000

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ── Security ───────────────────────────────────────────────────────────────────
# Password required in x-password header to call /whatsapp/sendmessage
WHATSAPP_API_PASSWORD=0937712618

# ── Puppeteer (set automatically by Dockerfile) ────────────────────────────────
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
